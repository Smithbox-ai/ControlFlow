{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://copilot-atlas.local/schemas/docwriter.execution-report.schema.json",
  "title": "DocWriterExecutionReport",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "agent",
    "status",
    "confidence",
    "abstain",
    "scope",
    "docs_created",
    "docs_updated",
    "parity_verified",
    "coverage_percentage",
    "definition_of_done",
    "next_steps"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "agent": { "type": "string", "const": "DocWriter-subagent" },
    "status": { "type": "string", "enum": ["COMPLETE", "NEEDS_INPUT", "FAILED", "ABSTAIN"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "failure_classification": {
      "type": "string",
      "enum": ["transient", "fixable", "needs_replan", "escalate"],
      "description": "Required when status is FAILED or NEEDS_INPUT. Classifies the failure type for Atlas retry/escalation logic."
    },
    "clarification_request": {
      "type": "object",
      "description": "Required when status is NEEDS_INPUT. Structured payload for Atlas to present to user via askQuestions.",
      "properties": {
        "options": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "description": { "type": "string" },
              "pros": { "type": "array", "items": { "type": "string" } },
              "cons": { "type": "array", "items": { "type": "string" } },
              "affected_files": { "type": "array", "items": { "type": "string" } }
            },
            "required": ["id", "description"]
          },
          "minItems": 2,
          "maxItems": 3
        },
        "impact_analysis": { "type": "string" },
        "recommended_option": { "type": "string" },
        "recommended_option_rationale": { "type": "string" }
      },
      "required": ["options", "impact_analysis", "recommended_option", "recommended_option_rationale"]
    },
    "abstain": {
      "type": "object",
      "additionalProperties": false,
      "required": ["is_abstaining", "reasons"],
      "properties": {
        "is_abstaining": { "type": "boolean" },
        "reasons": { "type": "array", "items": { "type": "string" } }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["in_scope", "out_of_scope"],
      "properties": {
        "in_scope": { "type": "array", "items": { "type": "string" } },
        "out_of_scope": { "type": "array", "items": { "type": "string" } }
      }
    },
    "docs_created": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "title", "type"],
        "properties": {
          "path": { "type": "string" },
          "title": { "type": "string" },
          "type": { "type": "string", "enum": ["documentation", "walkthrough", "diagram", "api_reference"] }
        }
      }
    },
    "docs_updated": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "changes"],
        "properties": {
          "path": { "type": "string" },
          "changes": { "type": "string" }
        }
      }
    },
    "parity_verified": {
      "type": "boolean",
      "description": "Whether generated/updated documentation matches source code accurately."
    },
    "coverage_percentage": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "description": "Percentage of assigned scope covered by documentation."
    },
    "diagrams_generated": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "format"],
        "properties": {
          "path": { "type": "string" },
          "format": { "type": "string", "enum": ["mermaid", "plantuml", "ascii"] },
          "renders_correctly": { "type": "boolean" }
        }
      }
    },
    "definition_of_done": {
      "type": "object",
      "additionalProperties": false,
      "required": ["all_items_complete", "unchecked_items"],
      "properties": {
        "all_items_complete": { "type": "boolean" },
        "unchecked_items": { "type": "array", "items": { "type": "string" } }
      }
    },
    "next_steps": { "type": "array", "items": { "type": "string" } }
  }
}
