{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://copilot-atlas.local/schemas/code-context-pack.schema.json",
  "title": "CodeContextPack",
  "description": "Compact CodeMapper artifact that summarizes entry points, symbols, call paths, and hotspots without raw dumps.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_type",
    "scope",
    "entry_points",
    "top_files",
    "call_paths",
    "hotspots",
    "expand_when"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "artifact_type": { "type": "string", "const": "CodeContextPack" },
    "trace_id": {
      "type": "string",
      "format": "uuid",
      "description": "Optional UUIDv4 for cross-agent trace correlation."
    },
    "scope": { "type": "string", "minLength": 10 },
    "entry_points": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10,
      "items": { "$ref": "#/$defs/location" }
    },
    "top_files": {
      "type": "array",
      "minItems": 1,
      "maxItems": 15,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "purpose"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "purpose": { "type": "string", "minLength": 3 },
          "read_priority": { "type": "string", "enum": ["must_read", "reference_only", "avoid_unless_needed"] }
        }
      }
    },
    "symbols": {
      "type": "array",
      "items": { "$ref": "#/$defs/location" }
    },
    "call_paths": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "path"],
        "properties": {
          "name": { "type": "string", "minLength": 3 },
          "path": { "type": "array", "minItems": 1, "items": { "type": "string" } }
        }
      }
    },
    "hotspots": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "risk"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "risk": { "type": "string", "minLength": 3 }
        }
      }
    },
    "expand_when": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 5 }
    }
  },
  "$defs": {
    "location": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "symbol"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "symbol": { "type": "string", "minLength": 1 },
        "line": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
