{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://copilot-atlas.local/schemas/spec-capture.schema.json",
  "title": "SpecCapture",
  "description": "Compact spec-before-plan artifact for non-trivial or ambiguous work.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_type",
    "task_title",
    "objective",
    "scope_in",
    "scope_out",
    "constraints",
    "acceptance_criteria",
    "validation_commands",
    "non_goals",
    "open_questions"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "artifact_type": { "type": "string", "const": "SpecCapture" },
    "trace_id": {
      "type": "string",
      "format": "uuid",
      "description": "Optional UUIDv4 for cross-agent trace correlation."
    },
    "task_title": { "type": "string", "minLength": 3 },
    "objective": { "type": "string", "minLength": 10 },
    "scope_in": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 3 } },
    "scope_out": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 3 } },
    "constraints": { "type": "array", "items": { "type": "string", "minLength": 3 } },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 5 }
    },
    "validation_commands": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 3 }
    },
    "non_goals": { "type": "array", "items": { "type": "string", "minLength": 3 } },
    "open_questions": { "type": "array", "items": { "type": "string", "minLength": 3 } },
    "decision_owner": {
      "type": "string",
      "description": "Agent or human owner for resolving remaining scope choices."
    }
  }
}
