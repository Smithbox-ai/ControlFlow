{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://copilot-atlas.local/schemas/research-brief.schema.json",
  "title": "ResearchBrief",
  "description": "Small-model-friendly research handoff artifact with ranked options and bounded evidence.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_type",
    "research_question",
    "summary",
    "top_files",
    "key_findings",
    "ranked_options",
    "uncertainties",
    "do_not_re_read"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "artifact_type": { "type": "string", "const": "ResearchBrief" },
    "trace_id": {
      "type": "string",
      "format": "uuid",
      "description": "Optional UUIDv4 for cross-agent trace correlation."
    },
    "research_question": { "type": "string", "minLength": 10 },
    "summary": { "type": "array", "minItems": 1, "maxItems": 5, "items": { "type": "string" } },
    "top_files": {
      "type": "array",
      "maxItems": 12,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "reason"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "reason": { "type": "string", "minLength": 3 },
          "symbols": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "key_findings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["finding", "evidence"],
        "properties": {
          "finding": { "type": "string", "minLength": 5 },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["file", "line_start"],
              "properties": {
                "file": { "type": "string", "minLength": 1 },
                "line_start": { "type": "integer", "minimum": 1 },
                "line_end": { "type": "integer", "minimum": 1 }
              }
            }
          }
        }
      }
    },
    "ranked_options": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["rank", "option", "tradeoffs", "confidence"],
        "properties": {
          "rank": { "type": "integer", "minimum": 1 },
          "option": { "type": "string", "minLength": 3 },
          "tradeoffs": { "type": "array", "items": { "type": "string" } },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "uncertainties": { "type": "array", "items": { "type": "string" } },
    "do_not_re_read": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Files already inspected that downstream agents should skip unless new evidence contradicts the brief."
    }
  }
}
