{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://copilot-atlas.local/schemas/orchestrator.delegation-protocol.schema.json",
  "title": "OrchestratorDelegationProtocol",
  "description": "Defines the structured parameters Orchestrator must provide when delegating to each subagent. Loaded on demand to avoid context bloat in Orchestrator prompt.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "agents"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "agents": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "CodeMapper-subagent",
        "Researcher-subagent",
        "Planner",
        "CoreImplementer-subagent",
        "UIImplementer-subagent",
        "PlatformEngineer-subagent",
        "TechnicalWriter-subagent",
        "BrowserTester-subagent",
        "CodeReviewer-subagent",
        "PlanAuditor-subagent",
        "AssumptionVerifier-subagent",
        "ExecutabilityVerifier-subagent"
      ],
      "properties": {
        "CodeMapper-subagent": {
          "type": "object",
          "additionalProperties": false,
          "required": ["scope_description"],
          "properties": {
            "scope_description": { "type": "string", "minLength": 5 },
            "focus_areas": { "type": "array", "items": { "type": "string" } },
            "conventions_requested": { "type": "boolean" },
            "resource_profile": { "$ref": "#/$defs/resourceProfile" },
            "runtime_model_mode": { "$ref": "#/$defs/runtimeModelMode" },
            "model": { "$ref": "#/$defs/payloadModelField" }
          },
          "allOf": [{ "$ref": "#/$defs/modelRequirementByRuntimeMode" }]
        },
        "Researcher-subagent": {
          "type": "object",
          "additionalProperties": false,
          "required": ["research_query"],
          "properties": {
            "research_query": { "type": "string", "minLength": 5 },
            "focus_areas": { "type": "array", "items": { "type": "string" } },
            "complexity": { "type": "string", "enum": ["simple", "medium", "complex"] },
            "resource_profile": { "$ref": "#/$defs/resourceProfile" },
            "runtime_model_mode": { "$ref": "#/$defs/runtimeModelMode" },
            "model": { "$ref": "#/$defs/payloadModelField" },
            "context_packet": { "$ref": "#/$defs/contextPacket" }
          },
          "allOf": [{ "$ref": "#/$defs/modelRequirementByRuntimeMode" }]
        },
        "Planner": {
          "type": "object",
          "additionalProperties": false,
          "required": ["task_description"],
          "properties": {
            "task_description": { "type": "string", "minLength": 10 },
            "constraints": { "type": "array", "items": { "type": "string" } },
            "context_refs": { "type": "array", "items": { "type": "string" } },
            "resource_profile": { "$ref": "#/$defs/resourceProfile" },
            "runtime_model_mode": { "$ref": "#/$defs/runtimeModelMode" },
            "trace_id": {
              "type": "string",
              "format": "uuid",
              "description": "UUID v4 for cross-agent trace correlation. Phase 3 keeps this compatibility-safe for base Planner payloads; replan/update modes require it conditionally."
            },
            "iteration_index": {
              "type": "integer",
              "minimum": 0,
              "description": "Review-loop iteration index. Required conditionally for Planner replan/update payloads."
            },
            "revision_mode": {
              "type": "string",
              "enum": ["initial_create", "in_place_update", "new_artifact_supersession"],
              "description": "Optional in the base Planner payload during Phase 3 compatibility. Orchestrator uses initial_create when no active plan exists, in_place_update for ordinary PLAN_REVIEW fixes, and new_artifact_supersession for accepted-baseline replacement, user-requested new artifacts, material invalidation, or independent citation needs."
            },
            "revision_reason": {
              "type": "string",
              "minLength": 5,
              "description": "Concise reason for the requested plan revision. Required for in_place_update and new_artifact_supersession."
            },
            "active_plan_path": {
              "type": "string",
              "minLength": 1,
              "description": "Existing active plan artifact Planner may edit when revision_mode is in_place_update."
            },
            "existing_plan_path": {
              "type": "string",
              "minLength": 1,
              "description": "Prior plan artifact that a new superseding artifact replaces when revision_mode is new_artifact_supersession."
            },
            "model": { "$ref": "#/$defs/payloadModelField" }
          },
          "allOf": [
            { "$ref": "#/$defs/modelRequirementByRuntimeMode" },
            {
              "if": {
                "properties": { "revision_mode": { "const": "in_place_update" } },
                "required": ["revision_mode"]
              },
              "then": {
                "required": ["active_plan_path", "revision_reason", "trace_id", "iteration_index"]
              }
            },
            {
              "if": {
                "properties": { "revision_mode": { "const": "new_artifact_supersession" } },
                "required": ["revision_mode"]
              },
              "then": {
                "required": ["existing_plan_path", "revision_reason", "trace_id", "iteration_index"]
              }
            }
          ]
        },
        "CoreImplementer-subagent": {
          "type": "object",
          "additionalProperties": false,
          "required": ["task_id", "phase_id", "task_definition"],
          "properties": {
            "task_id": { "type": "string" },
            "phase_id": { "type": "integer", "minimum": 1 },
            "phase_type": {
              "type": "string",
              "enum": ["modifying", "read_only"],
              "description": "Phase execution type from the Planner plan."
            },
            "task_definition": { "type": "string", "minLength": 10 },
            "context_files": { "type": "array", "items": { "type": "string" } },
            "resource_profile": { "$ref": "#/$defs/resourceProfile" },
            "runtime_model_mode": { "$ref": "#/$defs/runtimeModelMode" },
            "model": { "$ref": "#/$defs/payloadModelField" },
            "context_packet": { "$ref": "#/$defs/contextPacket" },
            "phase_task_card": { "$ref": "#/$defs/phaseTaskCard" }
          },
          "allOf": [{ "$ref": "#/$defs/modelRequirementByRuntimeMode" }]
        },
        "UIImplementer-subagent": {
          "type": "object",
          "additionalProperties": false,
          "required": ["task_id", "phase_id", "task_definition"],
          "properties": {
            "task_id": { "type": "string" },
            "phase_id": { "type": "integer", "minimum": 1 },
            "phase_type": {
              "type": "string",
              "enum": ["modifying", "read_only"],
              "description": "Phase execution type from the Planner plan."
            },
            "task_definition": { "type": "string", "minLength": 10 },
            "design_refs": { "type": "array", "items": { "type": "string" } },
            "resource_profile": { "$ref": "#/$defs/resourceProfile" },
            "runtime_model_mode": { "$ref": "#/$defs/runtimeModelMode" },
            "model": { "$ref": "#/$defs/payloadModelField" },
            "context_packet": { "$ref": "#/$defs/contextPacket" },
            "phase_task_card": { "$ref": "#/$defs/phaseTaskCard" }
          },
          "allOf": [{ "$ref": "#/$defs/modelRequirementByRuntimeMode" }]
        },
        "PlatformEngineer-subagent": {
          "type": "object",
          "additionalProperties": false,
          "required": ["task_id", "phase_id", "environment"],
          "properties": {
            "task_id": { "type": "string" },
            "phase_id": { "type": "integer", "minimum": 1 },
            "phase_type": {
              "type": "string",
              "enum": ["modifying", "read_only"],
              "description": "Phase execution type from the Planner plan."
            },
            "task_definition": { "type": "string" },
            "environment": { "type": "string", "enum": ["development", "staging", "production"] },
            "requires_approval": { "type": "boolean" },
            "security_sensitive": { "type": "boolean" },
            "resource_profile": { "$ref": "#/$defs/resourceProfile" },
            "runtime_model_mode": { "$ref": "#/$defs/runtimeModelMode" },
            "model": { "$ref": "#/$defs/payloadModelField" },
            "context_packet": { "$ref": "#/$defs/contextPacket" },
            "phase_task_card": { "$ref": "#/$defs/phaseTaskCard" }
          },
          "allOf": [{ "$ref": "#/$defs/modelRequirementByRuntimeMode" }]
        },
        "TechnicalWriter-subagent": {
          "type": "object",
          "additionalProperties": false,
          "required": ["task_id", "phase_id", "task_type"],
          "properties": {
            "task_id": { "type": "string" },
            "phase_id": { "type": "integer", "minimum": 1 },
            "phase_type": {
              "type": "string",
              "enum": ["modifying", "read_only"],
              "description": "Phase execution type from the Planner plan."
            },
            "task_type": { "type": "string", "enum": ["documentation", "walkthrough", "update"] },
            "audience": { "type": "string", "enum": ["developers", "end_users", "stakeholders"] },
            "coverage_matrix": { "type": "array", "items": { "type": "string" } },
            "resource_profile": { "$ref": "#/$defs/resourceProfile" },
            "runtime_model_mode": { "$ref": "#/$defs/runtimeModelMode" },
            "model": { "$ref": "#/$defs/payloadModelField" },
            "context_packet": { "$ref": "#/$defs/contextPacket" },
            "phase_task_card": { "$ref": "#/$defs/phaseTaskCard" }
          },
          "allOf": [{ "$ref": "#/$defs/modelRequirementByRuntimeMode" }]
        },
        "BrowserTester-subagent": {
          "type": "object",
          "additionalProperties": false,
          "required": ["task_id", "phase_id"],
          "properties": {
            "task_id": { "type": "string" },
            "phase_id": { "type": "integer", "minimum": 1 },
            "phase_type": {
              "type": "string",
              "enum": ["modifying", "read_only"],
              "description": "Phase execution type from the Planner plan."
            },
            "target_url": { "type": "string" },
            "health_endpoint": { "type": "string" },
            "validation_matrix": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["scenario", "expected_result"],
                "properties": {
                  "scenario": { "type": "string" },
                  "steps": { "type": "array", "items": { "type": "string" } },
                  "expected_result": { "type": "string" }
                }
              }
            },
            "resource_profile": { "$ref": "#/$defs/resourceProfile" },
            "runtime_model_mode": { "$ref": "#/$defs/runtimeModelMode" },
            "model": { "$ref": "#/$defs/payloadModelField" },
            "context_packet": { "$ref": "#/$defs/contextPacket" },
            "phase_task_card": { "$ref": "#/$defs/phaseTaskCard" }
          },
          "allOf": [{ "$ref": "#/$defs/modelRequirementByRuntimeMode" }]
        },
        "CodeReviewer-subagent": {
          "type": "object",
          "additionalProperties": false,
          "required": ["phase_id", "changed_files"],
          "properties": {
            "phase_id": { "type": "integer", "minimum": 0 },
            "phase_type": {
              "type": "string",
              "enum": ["modifying", "read_only"],
              "description": "Phase execution type from the Planner plan. Orchestrator skips CodeReviewer dispatch for read_only phases instead of sending an empty changed_files array."
            },
            "changed_files": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
            "review_depth": { "type": "string", "enum": ["full", "standard", "lightweight"] },
            "security_sensitive": { "type": "boolean" },
            "review_scope": {
              "type": "string",
              "enum": ["phase", "wave", "final"],
              "description": "Scope of this review dispatch. 'final' triggers holistic Completion Gate review across all phases; 'phase' is per-phase implementation review; 'wave' is cross-phase wave review."
            },
            "review_mode": {
              "type": "string",
              "enum": ["standard", "security"],
              "description": "Optional dispatch hint. 'security' MUST cause CodeReviewer to load skills/patterns/security-review-discipline.md before producing a verdict."
            },
            "plan_phases_snapshot": {
              "type": "array",
              "description": "Injected by Orchestrator for review_scope=final. Maps phase_id to its planned files for out-of-scope detection.",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["phase_id", "files"],
                "properties": {
                  "phase_id": { "type": "integer", "minimum": 1 },
                  "files": { "type": "array", "items": { "type": "string" } }
                }
              }
            },
            "prior_phase_findings": {
              "type": "array",
              "description": "Injected by Orchestrator for review_scope=final. Each entry is the CodeReviewer verdict from a prior phase review, enabling novelty filtering without requiring CodeReviewer to self-source plans/artifacts/.",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["phase_id", "review_scope", "status"],
                "properties": {
                  "phase_id": { "type": "integer", "minimum": 1 },
                  "review_scope": { "type": "string", "enum": ["phase", "wave"] },
                  "status": { "type": "string", "enum": ["APPROVED", "NEEDS_REVISION", "FAILED", "ABSTAIN"] },
                  "issues": { "type": "array", "items": { "type": "object" } },
                  "validated_blocking_issues": { "type": "array", "items": { "type": "object" } }
                }
              }
            },
            "phase_scope": {
              "description": "Optional. Describes the scope of the phase being reviewed (e.g., phase name, objectives, or relevant context).",
              "oneOf": [
                { "type": "string" },
                { "type": "object" }
              ]
            },
            "executor_report": {
              "type": "object",
              "description": "Optional. The execution report from the implementing agent for the phase being reviewed.",
              "additionalProperties": true
            },
            "runtime_model_mode": { "$ref": "#/$defs/runtimeModelMode" },
            "model": { "$ref": "#/$defs/payloadModelField" }
          },
          "allOf": [{ "$ref": "#/$defs/modelRequirementByRuntimeMode" }]
        },
        "PlanAuditor-subagent": {
          "type": "object",
          "additionalProperties": false,
          "required": ["task_id", "plan_path", "plan_summary", "trace_id", "iteration_index"],
          "properties": {
            "task_id": { "type": "string" },
            "trace_id": {
              "type": "string",
              "format": "uuid",
              "description": "UUID v4 for log correlation across the multi-agent review chain."
            },
            "iteration_index": {
              "type": "integer",
              "minimum": 0,
              "description": "Current iteration in the plan-review loop."
            },
            "plan_path": {
              "type": "string",
              "minLength": 1,
              "description": "Path to the persisted plan artifact. PlanAuditor reads the file directly rather than relying on inline prompt summaries."
            },
            "plan_summary": {
              "type": "string",
              "minLength": 10,
              "description": "Concise summary of the plan for initial context. PlanAuditor uses this for triage before reading the full plan."
            },
            "focus_areas": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["security", "architecture", "dependency_conflict", "scope_gap", "test_coverage", "destructive_risk", "performance", "contract_violation", "missing_rollback"]
              },
              "description": "Optional audit focus areas. If omitted, PlanAuditor performs a full-spectrum audit."
            },
            "retry_attempt": {
              "type": "integer",
              "minimum": 0,
              "description": "Retry attempt counter for exponential backoff signaling."
            },
            "runtime_model_mode": { "$ref": "#/$defs/runtimeModelMode" },
            "model": { "$ref": "#/$defs/payloadModelField" }
          },
          "allOf": [{ "$ref": "#/$defs/modelRequirementByRuntimeMode" }]
        },
        "AssumptionVerifier-subagent": {
          "type": "object",
          "additionalProperties": false,
          "required": ["plan_path", "plan_summary", "trace_id", "iteration_index"],
          "properties": {
            "trace_id": {
              "type": "string",
              "format": "uuid",
              "description": "UUID v4 for log correlation across the multi-agent review chain."
            },
            "plan_path": {
              "type": "string",
              "minLength": 1,
              "description": "Path to the persisted plan artifact."
            },
            "plan_summary": {
              "type": "string",
              "minLength": 10,
              "description": "Concise summary for initial context."
            },
            "focus_areas": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Optional mirage detection focus areas."
            },
            "iteration_index": {
              "type": "integer",
              "minimum": 0,
              "description": "Current iteration in the plan-review loop."
            },
            "runtime_model_mode": { "$ref": "#/$defs/runtimeModelMode" },
            "model": { "$ref": "#/$defs/payloadModelField" }
          },
          "allOf": [{ "$ref": "#/$defs/modelRequirementByRuntimeMode" }]
        },
        "ExecutabilityVerifier-subagent": {
          "type": "object",
          "additionalProperties": false,
          "required": ["plan_path", "plan_summary", "trace_id", "iteration_index"],
          "properties": {
            "trace_id": {
              "type": "string",
              "format": "uuid",
              "description": "UUID v4 for log correlation across the multi-agent review chain."
            },
            "iteration_index": {
              "type": "integer",
              "minimum": 0,
              "description": "Current iteration in the plan-review loop."
            },
            "plan_path": {
              "type": "string",
              "minLength": 1,
              "description": "Path to the approved plan artifact."
            },
            "plan_summary": {
              "type": "string",
              "minLength": 10,
              "description": "Concise summary for initial context."
            },
            "project_file_tree": {
              "type": "string",
              "description": "Optional project directory tree for context."
            },
            "runtime_model_mode": { "$ref": "#/$defs/runtimeModelMode" },
            "model": { "$ref": "#/$defs/payloadModelField" }
          },
          "allOf": [{ "$ref": "#/$defs/modelRequirementByRuntimeMode" }]
        }
      }
    }
  },
  "$defs": {
    "runtimeModelMode": {
      "type": "string",
      "enum": ["deterministic", "auto"],
      "description": "Dispatch marker for model-selection mode. Omitted means deterministic for backward compatibility."
    },
    "resourceProfile": {
      "type": "string",
      "enum": ["default", "small_local"],
      "description": "Optional resource profile marker. small_local requests compact artifacts, file/read budgets, and phase task cards per governance/runtime-policy.json."
    },
    "payloadModelField": {
      "type": "string",
      "description": "Payload-level model field carrying governance-resolved model context for delegation contract, validation, and audit context. Runtime enforcement is the outer tool-call model parameter passed to agent/runSubagent; this payload field does not by itself override frontmatter or select the runtime model. Deterministic mode requires this payload field; auto mode may omit it when runtime_model_mode is auto."
    },
    "contextPacket": {
      "type": "object",
      "description": "Optional compact research digest. When present, executor should read artifact_path before opening raw source files and skip paths in do_not_re_read unless contradicting evidence is found.",
      "additionalProperties": false,
      "properties": {
        "artifact_path": {
          "type": "string",
          "description": "Path to a markdown research digest file produced by Researcher or Planner."
        },
        "summary": {
          "type": "string",
          "description": "3–5 bullet overview of research findings for quick orientation."
        },
        "key_findings": {
          "type": "array",
          "items": { "type": "string" },
          "description": "High-signal facts the executing agent should read before touching source files."
        },
        "do_not_re_read": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Already-explored file paths the executing agent should skip unless contradicting evidence is found."
        }
      }
    },
    "phaseTaskCard": {
      "type": "object",
      "description": "Compact executor handoff for resource-bounded phase execution.",
      "additionalProperties": false,
      "required": [
        "objective",
        "allowed_files",
        "forbidden_areas",
        "validation_commands",
        "acceptance_checks",
        "max_changed_files",
        "escalation_rule"
      ],
      "properties": {
        "objective": { "type": "string", "minLength": 10 },
        "allowed_files": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "forbidden_areas": { "type": "array", "items": { "type": "string" } },
        "context_artifacts": { "type": "array", "items": { "type": "string" } },
        "validation_commands": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "acceptance_checks": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "max_changed_files": { "type": "integer", "minimum": 1 },
        "max_files_to_read_before_replan": { "type": "integer", "minimum": 1 },
        "escalation_rule": {
          "type": "string",
          "description": "When the executor must stop and return NEEDS_INPUT, needs_replan, or escalate instead of expanding scope."
        }
      }
    },
    "modelRequirementByRuntimeMode": {
      "if": {
        "properties": { "runtime_model_mode": { "const": "auto" } },
        "required": ["runtime_model_mode"]
      },
      "then": {},
      "else": {
        "required": ["model"]
      }
    }
  }
}
