{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://copilot-atlas.local/schemas/clarification-request.schema.json",
  "title": "ClarificationRequest",
  "description": "Shared schema fragment for structured clarification payloads. Used by acting subagents when returning NEEDS_INPUT status. Orchestrator routes these payloads to the user via askQuestions.",
  "type": "object",
  "additionalProperties": false,
  "required": ["options", "impact_analysis", "recommended_option", "recommended_option_rationale"],
  "properties": {
    "trace_id": {
      "type": "string",
      "format": "uuid",
      "description": "Optional UUIDv4 for cross-agent trace correlation."
    },
    "options": {
      "type": "array",
      "minItems": 2,
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "description"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 5 },
          "pros": { "type": "array", "items": { "type": "string" } },
          "cons": { "type": "array", "items": { "type": "string" } },
          "affected_files": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "impact_analysis": {
      "type": "string",
      "minLength": 10,
      "description": "Description of the impact of the decision on the overall task."
    },
    "recommended_option": {
      "type": "string",
      "description": "ID of the recommended option."
    },
    "recommended_option_rationale": {
      "type": "string",
      "minLength": 10,
      "description": "Rationale for why the recommended option is preferred."
    }
  }
}
