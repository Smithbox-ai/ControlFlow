{
  "id": "pre-wave-cache-guard",
  "target_agent": "Orchestrator",
  "goal": "Orchestrator pre-wave cache guard produces a human-visible recommendation when similar recent work is detected in plans/artifacts/. The guard does not auto-complete phases, skip approval gates, or modify the wave execution plan.",
  "input": {
    "wave": 3,
    "phases_in_wave": ["Phase 5 - Skill Promotion", "Phase 6 - Cache Guard"],
    "recent_artifacts": [
      {
        "task_slug": "prior-skill-work",
        "completed_phases": ["skill-promotion-governance"],
        "scope_overlap": "Phase 5 - Skill Promotion"
      }
    ]
  },
  "expected": {
    "cache_guard_recommendation_surfaced": true,
    "no_phase_auto_completed": true,
    "no_approval_gate_skipped": true,
    "wave_execution_plan_unchanged": true,
    "guard_skips_silently_when_no_overlap": true
  }
}
