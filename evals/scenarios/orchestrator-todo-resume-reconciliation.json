{
  "id": "orchestrator-todo-resume-reconciliation",
  "target_agent": "Orchestrator",
  "goal": "Orchestrator reconciles #todos immediately after compaction, conversation resumption, or session restart before resuming any phase work, including active Phase 1",
  "input": {
    "resume_context": {
      "event": "context_compaction",
      "active_phase_id": "P1",
      "active_wave": 1,
      "plan_path": "plans/example-plan.md"
    },
    "plan": {
      "phases": [
        {
          "id": "P1",
          "wave": 1,
          "title": "Database migrations"
        },
        {
          "id": "P2",
          "wave": 2,
          "title": "API layer changes",
          "dependencies": ["P1"]
        }
      ]
    },
    "todo_state": {
      "known_after_resume": "unknown_or_stale",
      "open_todos": ["P1", "P2"]
    }
  },
  "expected": {
    "todo_tool_calls": {
      "on_resume_or_compaction": {
        "tool": "#todos",
        "action": "reconcile",
        "trigger": "context_compaction_or_resume",
        "active_phase_id": "P1",
        "must_be_first_action_after_resume": true,
        "must_occur_before_phase_work_resumes": true,
        "must_compare_against_plan_artifacts": true
      },
      "on_phase_review_pass": {
        "tool": "#todos",
        "action": "complete",
        "count_per_review_pass": 1,
        "one_completion_call_per_phase": true,
        "must_occur_after": "phase_review_gate_pass",
        "must_occur_before": "approval_pause",
        "must_not_batch_with_other_phases": true
      },
      "on_plan_completion": {
        "tool": "#todos",
        "action": "reconcile",
        "all_todos_completed": true,
        "must_not_produce_summary_with_open_todos": true
      },
      "on_prior_phase_open_before_next_phase_start": {
        "tool": "#todos",
        "action": "reconcile",
        "trigger": "prior_phase_todo_open",
        "must_use_todo_tool": true,
        "blocks_next_phase_start": true,
        "must_occur_before_next_phase_start": true,
        "applicable_phase_transitions": ["P1→P2"]
      }
    },
    "pre_phase_open_todo_reconcile_required": {
      "after_compaction_or_resume": true,
      "active_phase_1_included": true,
      "orchestrator_must": "use #todos to reconcile todo state before resuming active Phase 1 work",
      "before": "any_phase_work"
    },
    "must_not": [
      "resume active Phase 1 work after compaction before #todos reconciliation",
      "start a later phase while any prior phase todo remains open",
      "produce completion summary with open phase todos"
    ],
    "negative_cases": [
      {
        "case_id": "resume-active-phase-1-after-compaction",
        "description": "Active Phase 1 resume after compaction must still reconcile #todos before any Phase 1 work resumes.",
        "input": {
          "resume_context": {
            "event": "context_compaction",
            "active_phase_id": "P1"
          },
          "first_action_after_resume": "resume_phase_work"
        },
        "expected": {
          "rejected": true,
          "violates": "resume-active-phase-1-after-compaction",
          "required_behavior": "first action after compaction is a #todos reconciliation pass, even for active Phase 1"
        }
      }
    ]
  }
}