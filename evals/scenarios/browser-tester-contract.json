{
  "id": "browser-tester-contract",
  "target_agent": "BrowserTester-subagent",
  "goal": "Execution report is schema-compliant, health-first gate is enforced, and accessibility audit is included",
  "input": {
    "task": "Execute E2E browser test scenarios with accessibility verification",
    "risk_level": "low"
  },
  "expected": {
    "schema": "schemas/browser-tester.execution-report.schema.json",
    "required_status": [
      "COMPLETE",
      "NEEDS_INPUT",
      "FAILED",
      "ABSTAIN"
    ],
    "must_include": [
      "health_check",
      "scenarios_run",
      "scenarios_passed",
      "accessibility_issues",
      "definition_of_done"
    ],
    "invariants": {
      "health_first_gate": true,
      "source_code_read_only": true,
      "browser_sessions_closed": true
    },
    "conditional": {
      "on_health_failure": {
        "required_status": "ABSTAIN",
        "must_include_reason": "Target application health check failed"
      },
      "on_scenario_failure": {
        "must_include": [
          "evidence_path",
          "failure_classification"
        ]
      }
    }
  }
}
