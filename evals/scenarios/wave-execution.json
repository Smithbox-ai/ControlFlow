          "wave": 2,
          "title": "Agent A",
          "dependencies": [
            "P1"
          ]
        },
        {
          "id": "P3",
          "wave": 2,
          "title": "Agent B",
          "dependencies": [
            "P1"
          ]
        },
        {
          "id": "P4",
          "wave": 3,
          "title": "Integration",
          "dependencies": [
            "P2",
            "P3"
          ]
        }
      ],
      "max_parallel_agents": 3
    }
  },
  "expected": {
    "wave_order_respected": true,
