{
  "id": "verify-mirage-detection",
  "target_skill": "controlflow-verify",
  "goal": "Phase 2 of controlflow-verify detects presence mirages (P1–P10) and absence mirages (A11–A17) by checking each plan claim against the repository.",
  "input": {
    "plan_path": "plans/example-plan.md",
    "phase": 2,
    "tier": "LARGE"
  },
  "expected": {
    "presence_mirages": [
      { "id": "P1", "name": "Phantom API" },
      { "id": "P2", "name": "Version Mismatch" },
      { "id": "P3", "name": "Pattern Mismatch" },
      { "id": "P4", "name": "Missing Dependency" },
      { "id": "P5", "name": "File Path Hallucination" },
      { "id": "P6", "name": "Schema Mismatch" },
      { "id": "P7", "name": "Integration Fantasy" },
      { "id": "P8", "name": "Scope Creep" },
      { "id": "P9", "name": "Test Infrastructure Mismatch" },
      { "id": "P10", "name": "Concurrency Blindness" }
    ],
    "absence_mirages": [
      { "id": "A11", "name": "Missing Error Path" },
      { "id": "A12", "name": "Missing Validation" },
      { "id": "A13", "name": "Missing Edge Case" },
      { "id": "A14", "name": "Missing Requirement" },
      { "id": "A15", "name": "Missing Cleanup" },
      { "id": "A16", "name": "Missing Migration" },
      { "id": "A17", "name": "Missing Security Boundary" }
    ],
    "each_mirage_recorded_fields": ["claim", "pattern", "evidence", "verdict"],
    "unconfirmable_verdict": "uncertain",
    "mirage_catalog_reference": "references/mirage-patterns.md"
  },
  "assertions": [
    "controlflow-verify SKILL.md Phase 2 references the mirage-patterns.md catalog with P1–P10 and A11–A17.",
    "references/mirage-patterns.md lists exactly 10 presence mirages (P1–P10) and 7 absence mirages (A11–A17).",
    "An unconfirmable mirage is recorded as 'uncertain', not passed.",
    "Each mirage finding records the claim, the pattern id, the evidence checked, and the verdict."
  ]
}