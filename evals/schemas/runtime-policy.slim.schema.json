{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://copilot-atlas.local/schemas/runtime-policy.slim.schema.json",
  "title": "RuntimePolicySlim",
  "description": "Slim Copilot-first runtime policy. Only 3 blocks: review_pipeline_by_tier + semantic_risk_policy + verdict_routing. The 13 retired governance knobs (approval_required_actions, max_iterations_by_tier, retry_budgets, stagnation_detection, session_telemetry, tool_output_policy, plan_review_gate_trigger_conditions, batch_approval, budget_defaults, final_review_gate, memory_hygiene, compaction, task_cache) are delegated to the native Copilot runtime and are no longer required. This schema is the Phase 2 slim contract anchor used by validate.mjs + drift-detection.test.mjs; the legacy schemas/runtime-policy.schema.json remains in place (out of Phase 2 scope to modify) but is no longer used to validate the live governance file.",
  "type": "object",
  "additionalProperties": false,
  "required": ["review_pipeline_by_tier", "semantic_risk_policy", "verdict_routing"],
  "properties": {
    "_comment": { "type": "string" },
    "review_pipeline_by_tier": {
      "type": "object",
      "additionalProperties": false,
      "required": ["TRIVIAL", "SMALL", "MEDIUM", "LARGE"],
      "properties": {
        "TRIVIAL": { "$ref": "#/$defs/reviewPipeline" },
        "SMALL": { "$ref": "#/$defs/reviewPipeline" },
        "MEDIUM": { "$ref": "#/$defs/reviewPipeline" },
        "LARGE": { "$ref": "#/$defs/reviewPipeline" }
      }
    },
    "semantic_risk_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["categories", "applicability_values", "impact_values", "disposition_values", "override_rule"],
      "properties": {
        "_comment": { "type": "string" },
        "categories": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 7,
          "maxItems": 7,
          "uniqueItems": true
        },
        "applicability_values": {
          "type": "array",
          "items": { "type": "string", "enum": ["applicable", "not_applicable", "uncertain"] }
        },
        "impact_values": {
          "type": "array",
          "items": { "type": "string", "enum": ["HIGH", "MEDIUM", "LOW", "UNKNOWN"] }
        },
        "disposition_values": {
          "type": "array",
          "items": { "type": "string", "enum": ["resolved", "open_question", "research_phase_added", "not_applicable"] }
        },
        "override_rule": { "type": "string", "minLength": 1 }
      }
    },
    "verdict_routing": {
      "type": "object",
      "additionalProperties": false,
      "required": ["verdicts", "confidence_thresholds"],
      "properties": {
        "_comment": { "type": "string" },
        "verdicts": {
          "type": "object",
          "additionalProperties": false,
          "required": ["APPROVED", "NEEDS_REVISION", "REJECTED"],
          "properties": {
            "APPROVED": { "type": "string", "minLength": 1 },
            "NEEDS_REVISION": { "type": "string", "minLength": 1 },
            "REJECTED": { "type": "string", "minLength": 1 }
          }
        },
        "confidence_thresholds": {
          "type": "object",
          "additionalProperties": false,
          "required": ["ready_for_execution_min", "uncertain_count_cap", "high_impact_open_question_cap"],
          "properties": {
            "ready_for_execution_min": { "type": "number", "minimum": 0, "maximum": 1 },
            "uncertain_count_cap": { "type": "number", "minimum": 0, "maximum": 1 },
            "high_impact_open_question_cap": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        }
      }
    }
  },
  "$defs": {
    "reviewPipeline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["plan_auditor", "assumption_verifier", "executability_verifier", "code_review"],
      "properties": {
        "plan_auditor": { "type": "boolean" },
        "assumption_verifier": { "type": "boolean" },
        "executability_verifier": { "type": "boolean" },
        "code_review": { "type": "boolean" }
      }
    }
  }
}